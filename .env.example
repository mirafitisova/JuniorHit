# Database (Supabase or any PostgreSQL provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here

# Resend — for transactional emails (resend.com)
RESEND_API_KEY=re_your_api_key_here

# Base URL of the deployed app — used in email links
APP_URL=https://your-app.onrender.com

# Cron job secret — protects the parent reminder endpoint
# Set this as the Authorization: Bearer <value> header in your cron job
CRON_SECRET=your-cron-secret-here

# Server port (optional — defaults to 5000)
PORT=5000
